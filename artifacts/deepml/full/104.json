.0, -1.0], [-2.0, -2.0]]), torch.tensor([1.0, 1.0]), 0.0)\nprint(result.tolist())","expected_output":"[1, 1, 0, 0]"},{"test":"import torch\nresult = predict_logistic(torch.tensor([[0.0, 0.0], [0.1, 0.1], [-0.1, -0.1]]), torch.tensor([1.0, 1.0]), 0.0)\nprint(result.tolist())","expected_output":"[1, 1, 0]"},{"test":"import torch\nresult = predict_logistic(torch.tensor([[1.0, 2.0, 3.0], [-1.0, -2.0, -3.0], [0.5, 1.0, 1.5]]), torch.tensor([0.1, 0.2, 0.3]), -1.0)\nprint(result.tolist())","expected_output":"[1, 0, 0]"},{"test":"import torch\nresult = predict_logistic(torch.tensor([[1.0], [2.0], [-1.0], [-2.0]]), torch.tensor([2.0]), 0.0)\nprint(result.tolist())","expected_output":"[1, 1, 0, 0]"},{"test":"import torch\nresult = predict_logistic(torch.tensor([[1000.0, 2000.0], [-1000.0, -2000.0]]), torch.tensor([0.1, 0.1]), 0.0)\nprint(result.tolist())","expected_output":"[1, 0]"}],"pytorch_starter_code":"","tinygrad_test_cases":[{"test":"import numpy as np\nresult = predict_logistic(np.array([[1.0, 1.0], [2.0, 2.0], [-1.0, -1.0], [-2.0, -2.0]]), np.array([1.0, 1.0]), 0.0)\nprint(result.tolist())","expected_output":"[1, 1, 0, 0]"},{"test":"import numpy as np\nresult = predict_logistic(np.array([[0.0, 0.0], [0.1, 0.1], [-0.1, -0.1]]), np.array([1.0, 1.0]), 0.0)\nprint(result.tolist())","expected_output":"[1, 1, 0]"},{"test":"import numpy as np\nresult = predict_logistic(np.array([[1.0, 2.0, 3.0], [-1.0, -2.0, -3.0], [0.5, 1.0, 1.5]]), np.array([0.1, 0.2, 0.3]), -1.0)\nprint(result.tolist())","expected_output":"[1, 0, 0]"},{"test":"import numpy as np\nresult = predict_logistic(np.array([[1.0], [2.0], [-1.0], [-2.0]]), np.array([2.0]), 0.0)\nprint(result.tolist())","expected_output":"[1, 1, 0, 0]"},{"test":"import numpy as np\nresult = predict_logistic(np.array([[1000.0, 2000.0], [-1000.0, -2000.0]]), np.array([0.1, 0.1]), 0.0)\nprint(result.tolist())","expected_output":"[1, 0]"}]}