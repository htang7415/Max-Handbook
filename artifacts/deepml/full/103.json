":[{"profile_link":"https://github.com/Haleshot","name":"Haleshot"}],"pytorch_test_cases":[{"test":"import torch\nresult = selu(torch.tensor(1.0))\nprint(round(result.item(), 4))","expected_output":"1.0507"},{"test":"import torch\nresult = selu(torch.tensor(0.0))\nprint(round(result.item(), 4))","expected_output":"0.0"},{"test":"import torch\nresult = selu(torch.tensor(-1.0))\nprint(round(result.item(), 4))","expected_output":"-1.1113"},{"test":"import torch\nresult = selu(torch.tensor(5.0))\nprint(round(result.item(), 4))","expected_output":"5.2535"},{"test":"import torch\nresult = selu(torch.tensor(-5.0))\nprint(round(result.item(), 4))","expected_output":"-1.7463"}],"pytorch_starter_code":"","createdAt":"January 13, 2026 at 3:39:58 PM UTC-0500"}